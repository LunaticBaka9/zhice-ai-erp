<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.UserMapper">
    <select id="selectByUsername" resultType="com.example.demo.entity.User">
        SELECT * FROM `user` WHERE username=#{username}
    </select>

    <select id="selectById"  resultType="com.example.demo.entity.User">
        SELECT * FROM `user` WHERE uid=#{uid}
    </select>

    <select id="selectAllUsers" resultType="com.example.demo.entity.User">
        select * from `user`
        <where>
            <if test="username != null">username like concat('%', #{username}, '%')</if>
            <if test="name != null">and name like concat('%', #{name}, '%')</if>
            <if test="phone != null">and phone like concat('%', #{phone}, '%')</if>
            <if test="email != null">and email like concat('%', #{email}, '%')</if>
        </where>
    </select>

    <update id="updateStatusById">
        UPDATE `user`
        SET status=#{status}
        WHERE uid=#{uid}
    </update>

    <update id="updateInfoById" parameterType="com.example.demo.entity.User">
        UPDATE `user`
        SET name = #{name},role = #{role},department = #{department},
            bio = #{bio},joinDate = #{joinDate},
            status=#{status}
        WHERE uid = #{uid}
    </update>

    <update id="updatePasswordById" parameterType="com.example.demo.entity.User">
        UPDATE `user`
        SET password = #{password}
        WHERE uid = #{uid}
    </update>

    <insert id="insertUser">
        insert into `user` (username,name,password,email,role,department,phone,bio,joinDate,status,createTime)
        values(#{username},#{name}, #{password},#{email},#{role},#{department},#{phone},#{bio},#{joinDate},#{status},NOW())
    </insert>

    <delete id="deleteById">
        DELETE u, s FROM `user` u LEFT JOIN sign_record s ON u.uid = s.uid WHERE u.uid = #{uid}
    </delete>
</mapper>