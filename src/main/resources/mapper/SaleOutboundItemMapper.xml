<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.SaleOutboundItemMapper">

    <resultMap id="rowMap" type="com.example.demo.entity.SaleOutboundItem">
        <id column="id" property="id"/>
        <result column="outbound_id" property="outboundId"/>
        <result column="sale_order_item_id" property="saleOrderItemId"/>
        <result column="product_id" property="productId"/>
        <result column="quantity" property="quantity"/>
        <result column="price" property="price"/>
        <result column="product_name_snapshot" property="productNameSnapshot"/>
        <result column="sku_code" property="skuCode"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `sale_outbound_item` (outbound_id, sale_order_item_id, product_id, quantity, price)
        VALUES (#{outboundId}, #{saleOrderItemId}, #{productId}, #{quantity}, #{price})
    </insert>

    <delete id="deleteByOutboundId">
        DELETE FROM `sale_outbound_item` WHERE outbound_id = #{outboundId}
    </delete>

    <select id="selectByOutboundId" resultMap="rowMap">
        SELECT i.*, si.product_name_snapshot, g.sku_code AS sku_code
        FROM `sale_outbound_item` i
        LEFT JOIN sal_order_item si ON i.sale_order_item_id = si.id
        LEFT JOIN goods g ON i.product_id = g.id
        WHERE i.outbound_id = #{outboundId}
        ORDER BY i.id ASC
    </select>
</mapper>
